---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PageRail from '../../components/PageRail.astro';
import PostPreview from '../../components/PostPreview.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import { slugify } from '../../utils/common-utils';

export async function getStaticPaths() {
    const notes = ((await getCollection('notes')) ?? []).sort(sortItemsByDateDesc);
    const noteCount = notes.length;
    return notes.map((note, index) => ({
        params: { slug: note.slug },
        props: {
            note,
            prevNote: index + 1 !== noteCount ? notes[index + 1] : null,
            nextNote: index !== 0 ? notes[index - 1] : null
        }
    }));
}

type Props = { note: CollectionEntry<'notes'>; prevNote: CollectionEntry<'notes'>; nextNote: CollectionEntry<'notes'> };

const { href } = Astro.url;
const { note, prevNote, nextNote } = Astro.props;
const { title, publishDate, updatedDate, excerpt, tags = [], seo } = note.data;
const { Content } = await note.render();
const formatDate = (date: Date) =>
    date.toLocaleDateString('en-us', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    });
const readingMinutes = Math.max(1, Math.ceil((note.body || '').trim().split(/\s+/).filter(Boolean).length / 220));
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? excerpt} image={seo?.image} pageType="article" showHeader={false}>
    <PageRail
        slot="rail"
        eyebrow="Note"
        summary={excerpt}
        items={[
            { label: 'Published', value: formatDate(publishDate) },
            ...(updatedDate ? [{ label: 'Updated', value: formatDate(updatedDate) }] : []),
            { label: 'Reading time', value: `${readingMinutes} min` }
        ]}
        tags={tags.map((tag) => ({ label: `#${tag}` }))}
    />
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{title}</h1>
            <div class="mt-4 text-sm">
                <FormattedDate date={publishDate} />
                {
                    updatedDate && (
                        <>
                            {' '}
                            <span>
                                (Updated on <FormattedDate date={updatedDate} />)
                            </span>
                        </>
                    )
                }
            </div>
        </header>
        <div class="max-w-none prose prose-dante sm:prose-lg">
            <Content />
        </div>
        <div class="mt-8 flex flex-wrap items-center gap-6 text-sm justify-between sm:mt-12 sm:text-base">
            {
                tags.length > 0 && (
                    <div class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
                        {tags.map((tag) => (
                            <span class="text-main">
                                #{tag}
                            </span>
                        ))}
                    </div>
                )
            }
            <Button class="copy-url-button" aria-label="Copy link" data-url={href} data-tooltip-default="Copy link" data-tooltip-success="Copied">Share</Button>
        </div>
    </article>
    {
        (prevNote || nextNote) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">Read Next</h2>
                {nextNote && <PostPreview post={nextNote} basePath="/notes" class="mb-10 sm:mb-12" headingLevel="h3" />}
                {prevNote && <PostPreview post={prevNote} basePath="/notes" class="mb-10 sm:mb-12" headingLevel="h3" />}
            </div>
        )
    }
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const copyUrlButton = document.querySelector('.copy-url-button') as HTMLButtonElement;
        copyUrlButton?.addEventListener('click', async () => {
            await copyUrl(copyUrlButton);
        });

        async function copyUrl(button: HTMLButtonElement) {
            let url = button.getAttribute('data-url') || '';
            let label = button.innerText;

            await navigator.clipboard.writeText(url);

            button.innerText = 'Copied';

            setTimeout(() => {
                button.innerText = label;
            }, 2500);
        }
    });
</script>
