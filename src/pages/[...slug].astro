---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
    const pages = await getCollection('pages');
    return pages.map((page) => {
        return {
            params: { slug: page.slug },
            props: { page }
        };
    });
}

type Props = { page: CollectionEntry<'pages'> };

const { page } = Astro.props;
const { title, seo } = page.data;
const { Content } = await page.render();
const isContactPage = page.slug === 'contact';
---

<BaseLayout title={seo?.title ?? title} description={seo?.description} image={seo?.image} showHeader={false} showToc={!isContactPage}>
    <article class:list={['mb-16 sm:mb-24', isContactPage && 'mx-auto max-w-2xl text-center']}>
        <header class="mb-8">
            <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{title}</h1>
        </header>
        <div class:list={['max-w-none prose prose-dante sm:prose-lg', isContactPage && 'mx-auto']}>
            <Content />
        </div>
    </article>
</BaseLayout>
