<aside
    data-page-toc
    class="hidden xl:block xl:w-56 xl:shrink-0 transition-opacity duration-200 opacity-45 hover:opacity-100 focus-within:opacity-100"
    aria-label="Page table of contents"
>
    <div class="page-toc-panel overflow-y-auto pr-2">
        <p class="mb-4 font-serif text-lg italic">On This Page</p>
        <nav aria-label="Section navigation">
            <ol data-page-toc-list class="space-y-2 text-sm"></ol>
        </nav>
    </div>
</aside>

<script>
    function slugify(text) {
        return (text || '')
            .toLowerCase()
            .trim()
            .replace(/['".,()/]/g, '')
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-+|-+$/g, '');
    }

    function initPageToc() {
        const tocRoot = document.querySelector('[data-page-toc]');
        const tocList = document.querySelector('[data-page-toc-list]');
        const main = document.querySelector('main');

        if (!tocRoot || !tocList || !main) {
            return;
        }

        if (window.__pageTocObserver) {
            window.__pageTocObserver.disconnect();
        }

        const headings = [...main.querySelectorAll('h2, h3')].filter((heading) => heading.textContent?.trim());
        const usedIds = new Set();

        headings.forEach((heading) => {
            const baseId = heading.id || slugify(heading.textContent) || 'section';
            let uniqueId = baseId;
            let counter = 2;

            while (usedIds.has(uniqueId) || document.querySelectorAll(`#${CSS.escape(uniqueId)}`).length > (heading.id === uniqueId ? 1 : 0)) {
                uniqueId = `${baseId}-${counter}`;
                counter += 1;
            }

            heading.id = uniqueId;
            usedIds.add(uniqueId);
        });

        tocList.innerHTML = '';

        if (headings.length < 2) {
            tocRoot.style.display = 'none';
            return;
        }

        tocRoot.style.display = '';

        headings.forEach((heading) => {
            const item = document.createElement('li');
            item.className = heading.tagName === 'H3' ? 'pl-4' : '';

            const link = document.createElement('a');
            link.href = `#${heading.id}`;
            link.textContent = heading.textContent?.trim() || '';
            link.dataset.tocId = heading.id;
            link.className =
                'block border-l border-transparent pl-3 leading-relaxed text-main/65 transition hover:border-main/30 hover:text-main';

            item.appendChild(link);
            tocList.appendChild(item);
        });

        const links = [...tocList.querySelectorAll('a[data-toc-id]')];

        function setActive(activeId) {
            links.forEach((link) => {
                const isActive = link.dataset.tocId === activeId;
                link.dataset.active = isActive ? 'true' : 'false';
                link.classList.toggle('text-main', isActive);
                link.classList.toggle('font-medium', isActive);
                link.classList.toggle('border-main', isActive);
                link.classList.toggle('text-main/65', !isActive);
                link.classList.toggle('border-transparent', !isActive);
            });
        }

        const observer = new IntersectionObserver(
            (entries) => {
                const visibleHeadings = entries
                    .filter((entry) => entry.isIntersecting)
                    .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

                if (visibleHeadings.length > 0) {
                    setActive(visibleHeadings[0].target.id);
                    return;
                }

                const passed = headings.filter((heading) => heading.getBoundingClientRect().top < 160);
                if (passed.length > 0) {
                    setActive(passed[passed.length - 1].id);
                } else {
                    setActive(headings[0].id);
                }
            },
            {
                rootMargin: '-15% 0px -70% 0px',
                threshold: [0, 1]
            }
        );

        headings.forEach((heading) => observer.observe(heading));
        window.__pageTocObserver = observer;
        setActive(headings[0].id);
    }

    document.addEventListener('astro:page-load', initPageToc);
    initPageToc();
</script>

<style>
    @media (min-width: 1280px) {
        .page-toc-panel {
            position: fixed;
            top: 7rem;
            left: max(1.5rem, calc(50vw - 42rem));
            width: 14rem;
            max-height: calc(100vh - 8.5rem);
        }
    }
</style>
