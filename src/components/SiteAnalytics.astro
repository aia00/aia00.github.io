---
const analyticsEndpoint = (import.meta.env.PUBLIC_ANALYTICS_ENDPOINT || '').trim();
---

<script is:inline define:vars={{ analyticsEndpoint }}>
    (() => {
        const endpoint = analyticsEndpoint?.replace(/\/+$/, '');
        const TRACK_WINDOW_MS = 30 * 60 * 1000;
        const debugEnabled = new URLSearchParams(window.location.search).get('analytics_debug') === '1';

        if (!endpoint) {
            return;
        }

        function debugLog(message, details) {
            if (!debugEnabled) {
                return;
            }

            if (typeof details === 'undefined') {
                console.info('[analytics]', message);
                return;
            }

            console.info('[analytics]', message, details);
        }

        function getPagePayload(pathname) {
            const segments = pathname.split('/').filter(Boolean);

            if (segments.length === 0) {
                return { pageType: 'home' };
            }

            const [first, second] = segments;

            if (first === 'blog') {
                return second ? { pageType: 'blog', slug: second } : { pageType: 'blog-index' };
            }

            if (first === 'notes') {
                return second ? { pageType: 'note', slug: second } : { pageType: 'notes-index' };
            }

            if (first === 'projects') {
                return second ? { pageType: 'project', slug: second } : { pageType: 'projects-index' };
            }

            if (first === 'tags') {
                return second ? { pageType: 'tag', slug: second } : { pageType: 'tags-index' };
            }

            return { pageType: 'page', slug: segments.join('/') };
        }

        function shouldTrack(pathname) {
            return pathname && !pathname.startsWith('/rss.xml') && !pathname.startsWith('/sitemap');
        }

        function alreadyTrackedRecently(pathname) {
            try {
                const storageKey = `site-analytics:view:${pathname}`;
                const raw = window.localStorage.getItem(storageKey);
                const lastTrackedAt = raw ? Number(raw) : 0;

                if (lastTrackedAt && Date.now() - lastTrackedAt < TRACK_WINDOW_MS) {
                    return true;
                }

                window.localStorage.setItem(storageKey, String(Date.now()));
                return false;
            } catch {
                return false;
            }
        }

        let lastTrackedPath = '';

        function trackPageView() {
            const pathname = window.location.pathname;

            if (!shouldTrack(pathname)) {
                debugLog('skipped non-trackable path', { pathname });
                return;
            }

            if (navigator.doNotTrack === '1' || window.doNotTrack === '1') {
                debugLog('skipped because do-not-track is enabled', { pathname });
                return;
            }

            if (pathname === lastTrackedPath) {
                debugLog('deduped repeated in-memory navigation', { pathname });
                lastTrackedPath = pathname;
                return;
            }

            if (alreadyTrackedRecently(pathname)) {
                debugLog('deduped by localStorage window', { pathname, windowMs: TRACK_WINDOW_MS });
                lastTrackedPath = pathname;
                return;
            }

            lastTrackedPath = pathname;

            const payload = {
                path: pathname,
                referrer: document.referrer || undefined,
                ...getPagePayload(pathname)
            };

            const body = JSON.stringify(payload);
            const url = `${endpoint}/track`;
            debugLog('tracking page view', payload);

            try {
                if (navigator.sendBeacon) {
                    const blob = new Blob([body], { type: 'application/json' });
                    const queued = navigator.sendBeacon(url, blob);
                    debugLog('sendBeacon attempted', { pathname, queued });

                    if (queued === true) {
                        return;
                    }
                }
            } catch (error) {
                debugLog('sendBeacon threw; falling back to fetch', {
                    pathname,
                    error: error instanceof Error ? error.message : String(error)
                });
            }

            debugLog('falling back to fetch keepalive', { pathname });
            fetch(url, {
                method: 'POST',
                mode: 'cors',
                headers: { 'Content-Type': 'application/json' },
                body,
                keepalive: true
            })
                .then((response) => {
                    debugLog('fetch fallback completed', {
                        pathname,
                        status: response.status,
                        ok: response.ok
                    });
                })
                .catch((error) => {
                    debugLog('fetch fallback failed', {
                        pathname,
                        error: error instanceof Error ? error.message : String(error)
                    });
                });
        }

        if (window.__siteAnalyticsHandler) {
            document.removeEventListener('astro:page-load', window.__siteAnalyticsHandler);
        }

        window.__siteAnalyticsHandler = trackPageView;
        document.addEventListener('astro:page-load', window.__siteAnalyticsHandler);
        trackPageView();
    })();
</script>
